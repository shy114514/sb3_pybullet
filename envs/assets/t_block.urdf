<?xml version="1.0"?>
<robot name="t_block">

  <material name="red">
    <color rgba="0.8 0.2 0.2 1.0"/>
  </material>
  
  <link name="t_block_link">
    
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0.0235714286" rpy="0 0 0"/>
      <inertia ixx="0.0002841163" ixy="0" ixz="0" iyy="0.0003274878" iyz="0" izz="0.0000771714"/>
    </inertial>

    <!-- 几何体 1：T形的垂直躯干 (Stem) -->
    <visual>
      <!-- 置于坐标原点，一半在Z=0以上，一半在以下 -->
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.026 0.026 0.074"/> <!-- 长2.6cm, 宽2.6cm, 高7.4cm -->
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.026 0.026 0.074"/>
      </geometry>
    </collision>

    <!-- 几何体 2：T形的顶部横杠 (Top Bar) -->
    <visual>
      <!-- 将横杠平移到躯干的顶部 (Z = 躯干高度的一半 + 横杠高度的一半 = 0.037 + 0.013 = 0.05) -->
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.066 0.026 0.026"/> <!-- 长6.6cm, 宽2.6cm, 高2.6cm -->
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.066 0.026 0.026"/>
      </geometry>
    </collision>

  </link>
</robot>
